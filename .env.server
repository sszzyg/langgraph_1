# Knowledge Base Configuration
KB_DIR=.faiss

# Kimi (Moonshot AI) LLM Configuration
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_API_KEY=
KIMI_MODEL=moonshot-v1-8k
KIMI_TEMPERATURE=0.2
KIMI_TOP_P=0.9
KIMI_MAX_TOKENS=1024
KIMI_TIMEOUT_SECONDS=60

# SiliconFlow Embedding + Rerank
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=
SILICONFLOW_EMBEDDING_MODEL=Qwen/Qwen3-VL-Embedding-8B
SILICONFLOW_RERANK_MODEL=BAAI/bge-reranker-v2-m3
SILICONFLOW_RERANK_ENABLED=true
SILICONFLOW_TIMEOUT_SECONDS=60

# API Security Configuration (Optional)
TOOL_API_KEY=

# Server URL (for logs and notifications)
SERVER_URL=http://your-server-ip:8000
